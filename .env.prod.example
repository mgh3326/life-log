# Production Environment Variables for life-log
# Note: Database is expected to be running on the host machine as Compose uses network_mode: host

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/life_log
LOG_LEVEL=INFO
API_PORT=8100
MCP_HOST=0.0.0.0
MCP_PORT=8101
MCP_AUTH_TOKEN=your_secure_token_here
